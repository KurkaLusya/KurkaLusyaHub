-- GLOBAL ESP TOGGLE - ОДИНАКОВЫЕ ЦВЕТА У ВСЕХ
getgenv().ESP_TOGGLE = getgenv().ESP_TOGGLE or false
getgenv().GLOBAL_HUE = getgenv().GLOBAL_HUE or 0

local camera = workspace.CurrentCamera
local players = game:GetService("Players")
local runService = game:GetService("RunService")
local localPlayer = players.LocalPlayer

local espObjects = {}

-- ОЧИСТКА ВСЕГО
local function cleanup()
    for _, obj in pairs(espObjects) do
        if obj.text then obj.text:Remove() end
        for _, conn in pairs(obj.connections) do
            if conn then conn:Disconnect() end
        end
    end
    espObjects = {}
end

-- СОЗДАНИЕ ESP ДЛЯ ОДНОГО ИГРОКА
local function createESP(player, character)
    local humanoid = character:WaitForChild("Humanoid")
    local head = character:WaitForChild("Head")
    
    local text = Drawing.new("Text")
    text.Size = 16
    text.Center = true
    text.Outline = false
    text.Font = 3
    text.Color = Color3.fromRGB(255, 255, 255)
    
    local connections = {}
    
    connections.render = runService.RenderStepped:Connect(function()
        if not getgenv().ESP_TOGGLE then 
            cleanup()
            return 
        end
        
        local pos, onScreen = camera:WorldToViewportPoint(head.Position)
        if onScreen then
            text.Position = Vector2.new(pos.X, pos.Y - 30)
            text.Text = "[" .. player.Name .. "]"
            text.Visible = true
            -- ОДИНАКОВЫЙ ЦВET ДЛЯ ВСЕХ ИЗ getgenv().GLOBAL_HUE
            text.Color = Color3.fromHSV(getgenv().GLOBAL_HUE, 1, 1)
        else
            text.Visible = false
        end
    end)
    
    connections.death = humanoid.Died:Connect(function()
        cleanupESP(player)
    end)
    
    connections.removed = character.AncestryChanged:Connect(function()
        if not character.Parent then
            cleanupESP(player)
        end
    end)
    
    espObjects[player] = {
        text = text,
        connections = connections
    }
end

local function cleanupESP(player)
    if espObjects[player] then
        local obj = espObjects[player]
        if obj.text then obj.text:Remove() end
        for _, conn in pairs(obj.connections) do
            if conn then conn:Disconnect() end
        end
        espObjects[player] = nil
    end
end

-- ТОГГЛ
if getgenv().ESP_TOGGLE then
    getgenv().ESP_TOGGLE = false
    cleanup()
    print("ESP ВЫКЛЮЧЕН")
else
    getgenv().ESP_TOGGLE = true
    cleanup() -- чистим старое
    
    -- ГЛОБАЛЬНАЯ АНИМАЦИЯ ЦВЕТА ДЛЯ ВСЕХ (синхронизированная)
    spawn(function()
        while getgenv().ESP_TOGGLE do
            getgenv().GLOBAL_HUE = getgenv().GLOBAL_HUE + 0.008
            if getgenv().GLOBAL_HUE >= 1 then 
                getgenv().GLOBAL_HUE = 0 
            end
            wait()
        end
    end)
    
    -- ВСЕ ИГРОКИ
    for _, player in pairs(players:GetPlayers()) do
        if player ~= localPlayer and player.Character then
            createESP(player, player.Character)
        end
    end
    
    print("ESP ВКЛЮЧЕН - ОДИНАКОВЫЕ ЦВЕТА!")
end

-- НОВЫЕ ИГРОКИ
players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(character)
        if getgenv().ESP_TOGGLE then
            createESP(player, character)
        end
    end)
end)
