local Players = game:GetService("Players")

local player = Players.LocalPlayer

-- создаём состояние если нет
if player:GetAttribute("SpeedToggle") == nil then
	player:SetAttribute("SpeedToggle", false)
end

local FAST_SPEED = 17.4
local DEFAULT_SPEED = 16

-- храним соединение в Attribute нельзя, поэтому через _G
_G.SpeedConnection = _G.SpeedConnection or nil

local function apply(character)
	local humanoid = character:WaitForChild("Humanoid")

	-- очищаем старое соединение
	if _G.SpeedConnection then
		_G.SpeedConnection:Disconnect()
		_G.SpeedConnection = nil
	end

	local toggled = player:GetAttribute("SpeedToggle")

	if toggled then
		-- ВКЛ
		humanoid.WalkSpeed = FAST_SPEED

		_G.SpeedConnection = humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
			if humanoid.WalkSpeed ~= FAST_SPEED then
				humanoid.WalkSpeed = FAST_SPEED
			end
		end)
	else
		-- ВЫКЛ
		humanoid.WalkSpeed = DEFAULT_SPEED
	end
end

-- 🔁 ПЕРЕКЛЮЧЕНИЕ
local toggled = player:GetAttribute("SpeedToggle")
player:SetAttribute("SpeedToggle", not toggled)

-- применяем
local character = player.Character or player.CharacterAdded:Wait()
apply(character)

-- респавн
player.CharacterAdded:Connect(function(char)
	task.wait(0.2)
	apply(char)
end)
