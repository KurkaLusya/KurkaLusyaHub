local Players = game:GetService("Players")
local player = Players.LocalPlayer

if player:GetAttribute("ChickenMask") == nil then
	player:SetAttribute("ChickenMask", false)
end

local IMAGE_ID = "rbxassetid://118435609581479"

local BODY_PARTS = {
	Head = true,
	UpperTorso = true,
	LowerTorso = true,
	LeftUpperArm = true,
	LeftLowerArm = true,
	RightUpperArm = true,
	RightLowerArm = true,
	LeftUpperLeg = true,
	LeftLowerLeg = true,
	RightUpperLeg = true,
	RightLowerLeg = true
}

local FACES = {
	Enum.NormalId.Front,
	Enum.NormalId.Back,
	Enum.NormalId.Left,
	Enum.NormalId.Right,
	Enum.NormalId.Top,
	Enum.NormalId.Bottom
}

local function addToPart(part)
	if part:FindFirstChild("ChickenMaskFolder") then return end

	local folder = Instance.new("Folder")
	folder.Name = "ChickenMaskFolder"
	folder.Parent = part

	for _, face in ipairs(FACES) do
		local surface = Instance.new("SurfaceGui")
		surface.Face = face
		surface.AlwaysOnTop = true
		surface.Adornee = part
		surface.Parent = folder

		local image = Instance.new("ImageLabel")
		image.Size = UDim2.new(1, 0, 1, 0)
		image.BackgroundTransparency = 1
		image.Image = IMAGE_ID
		image.Parent = surface
	end
end

local function setupCharacter(char)
	-- применяем сразу если уже есть части
	for _, v in ipairs(char:GetDescendants()) do
		if v:IsA("BasePart") and BODY_PARTS[v.Name] then
			addToPart(v)
		end
	end

	-- ГЛАВНЫЙ ФИКС: ловим ВСЕ будущие части
	char.DescendantAdded:Connect(function(obj)
		if obj:IsA("BasePart") and BODY_PARTS[obj.Name] then
			addToPart(obj)
		end
	end)
end

local function applyToAll()
	local enabled = player:GetAttribute("ChickenMask")

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			if plr.Character then
				if enabled then
					setupCharacter(plr.Character)
				else
					-- удаление
					for _, v in ipairs(plr.Character:GetDescendants()) do
						if v:IsA("BasePart") then
							local f = v:FindFirstChild("ChickenMaskFolder")
							if f then f:Destroy() end
						end
					end
				end
			end

			plr.CharacterAdded:Connect(function(char)
				if player:GetAttribute("ChickenMask") then
					setupCharacter(char)
				end
			end)
		end
	end
end

-- toggle
player:SetAttribute("ChickenMask", not player:GetAttribute("ChickenMask"))

applyToAll()

Players.PlayerAdded:Connect(function(plr)
	plr.CharacterAdded:Connect(function(char)
		if player:GetAttribute("ChickenMask") then
			setupCharacter(char)
		end
	end)
end)
